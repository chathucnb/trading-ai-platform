# ── Data Provider APIs ──────────────────────────────────────────────────
# Twelve Data — https://twelvedata.com (free: 800 credits/day)
TWELVE_DATA_API_KEY=your_twelve_data_key
# Finnhub — https://finnhub.io (free: 60 calls/min)
FINNHUB_API_KEY=your_finnhub_key
# Alpha Vantage — https://www.alphavantage.co (free: 25/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key
# CoinGecko — https://www.coingecko.com/en/api (optional, increases rate limit)
COINGECKO_API_KEY=

# ── AI Agent ───────────────────────────────────────────────────────────
# Anthropic — https://console.anthropic.com (required for AI agents)
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Stripe Payments ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_PREMIUM=price_...

# ── Infrastructure ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://forex_user:forex_password@localhost:5432/forex_db
PORT=3000
NODE_ENV=development

# ── Frontend ──────────────────────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:3000/ws
